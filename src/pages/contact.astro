---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<html lang="en">
  <head>
    <title>Contact | Sandikala Studio</title>
    <meta
      name="description"
      content="Start a website design or Webflow development project with Sandikala Studio."
    />
  </head>

  <body>
    <BaseLayout
      title="Contact | Sandikala Studio"
      description="Start a website design or Webflow development project with Sandikala Studio."
    >
      <main>
        <nav>
          <a href="/">Sandikala Studio</a>
          <div>
            <a href="/work">Work</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>

        <section class="hero">
          <p>Contact</p>
          <h1>Tell us what you’re building.</h1>
        </section>

        <section class="contact-grid">
          <div>
            <h2>Start a project</h2>
            <p>
              For new website, brand, or Webflow development enquiries, send a
              short note about your project, timeline, and what you are hoping
              to improve.
            </p>
          </div>

          <div class="contact-card">
            <p>Email</p>
            <a href="mailto:hello@sandikalastudio.com"
              >hello@sandikalastudio.com</a
            >
          </div>

          <div class="contact-card">
            <p>Book a call</p>
            <a
              href="https://cal.com/sandikalastudio"
              target="_blank"
              rel="noreferrer"
            >
              Schedule via Cal.com
            </a>
          </div>

          <div class="contact-card">
            <p>Typical projects</p>
            <ul>
              <li>Custom website design</li>
              <li>Webflow development</li>
              <li>Brand refresh + website</li>
              <li>Interaction-heavy marketing sites</li>
            </ul>
          </div>
        </section>

        <section class="note">
          <p>
            We usually work on project-based engagements, with website projects
            starting around USD 5,000 depending on scope, pages, CMS needs, and
            interaction complexity.
          </p>
        </section>
      </main>
    </BaseLayout>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #171717;
    color: #f7f4ef;
  }

  main {
    padding: 32px 48px 80px;
  }

  nav {
    display: flex;
    justify-content: space-between;
    gap: 24px;
  }

  nav div {
    display: flex;
    gap: 20px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    opacity: 0.6;
  }

  .hero {
    margin-top: 120px;
  }

  .hero p {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
  }

  h1 {
    max-width: 1100px;
    font-size: clamp(64px, 13vw, 180px);
    line-height: 0.86;
    letter-spacing: -0.08em;
    margin: 16px 0 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 24px;
    margin-top: 120px;
  }

  .contact-grid > div {
    border-top: 1px solid rgba(247, 244, 239, 0.24);
    padding-top: 24px;
  }

  h2 {
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-top: 0;
  }

  .contact-grid p {
    max-width: 560px;
    font-size: 18px;
    line-height: 1.5;
    opacity: 0.75;
  }

  .contact-card a {
    display: inline-block;
    font-size: clamp(28px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.05em;
    margin-top: 16px;
  }

  ul {
    padding: 0;
    list-style: none;
    margin: 24px 0 0;
  }

  li {
    padding: 8px 0;
    border-bottom: 1px solid rgba(247, 244, 239, 0.16);
  }

  .note {
    margin-top: 120px;
    border-top: 1px solid rgba(247, 244, 239, 0.24);
    padding-top: 24px;
  }

  .note p {
    max-width: 900px;
    font-size: clamp(28px, 4vw, 64px);
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  @media (max-width: 768px) {
    main {
      padding: 24px;
    }

    nav {
      flex-direction: column;
    }

    .hero,
    .contact-grid,
    .note {
      margin-top: 80px;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
