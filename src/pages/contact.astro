---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Sandikala Studio"
  description="Start a website design or Webflow development project with Sandikala Studio."
  theme="dark"
>
  <main class="contact-page">
    <section class="hero">
      <p>Contact</p>
      <h1>Tell us what you’re building.</h1>
    </section>

    <section class="contact-grid">
      <div>
        <h2>Start a project</h2>
        <p>
          For new website, brand, or Webflow development enquiries, send a
          short note about your project, timeline, and what you are hoping to
          improve.
        </p>
      </div>

      <form
        class="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        action="/thank-you"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="field-row">
          <label for="name">Name</label>
          <input
            id="name"
            name="Name"
            type="text"
            autocomplete="name"
            required
          />
        </div>

        <div class="field-row">
          <label for="email">Email</label>
          <input
            id="email"
            name="Email"
            type="email"
            autocomplete="email"
            required
          />
        </div>

        <div class="field-row">
          <label for="company">Company</label>
          <input
            id="company"
            name="Company"
            type="text"
            autocomplete="organization"
          />
        </div>

        <div class="field-row">
          <label for="budget">Budget</label>
          <select id="budget" name="Budget">
            <option value="">Select range</option>
            <option value="USD 5,000 - 10,000">USD 5,000 - 10,000</option>
            <option value="USD 10,000 - 20,000">USD 10,000 - 20,000</option>
            <option value="USD 20,000+">USD 20,000+</option>
            <option value="Not sure yet">Not sure yet</option>
          </select>
        </div>

        <div class="field-row">
          <label for="timeline">Timeline</label>
          <select id="timeline" name="Timeline">
            <option value="">Select timeline</option>
            <option value="ASAP">ASAP</option>
            <option value="1 - 2 months">1 - 2 months</option>
            <option value="3 - 6 months">3 - 6 months</option>
            <option value="Flexible">Flexible</option>
          </select>
        </div>

        <div class="field-row field-row-full">
          <label for="message">Project details</label>
          <textarea
            id="message"
            name="Project details"
            rows="6"
            placeholder="Tell us about the site, goals, pages, CMS needs, and references."
            required></textarea>
        </div>

        <button type="submit">Send enquiry</button>
      </form>

      <div class="contact-card">
        <p>Email</p>
        <a href="mailto:hello@sandikalastudio.com">
          hello@sandikalastudio.com
        </a>
      </div>

      <div class="contact-card">
        <p>Book a call</p>
        <a
          href="https://cal.com/sandikalastudio"
          target="_blank"
          rel="noreferrer"
        >
          Schedule via Cal.com
        </a>
      </div>

      <div class="contact-card">
        <p>Typical projects</p>
        <ul>
          <li>Custom website design</li>
          <li>Webflow development</li>
          <li>Brand refresh + website</li>
          <li>Interaction-heavy marketing sites</li>
        </ul>
      </div>
    </section>

    <section class="note">
      <p>
        We usually work on project-based engagements, with website projects
        starting around USD 5,000 depending on scope, pages, CMS needs, and
        interaction complexity.
      </p>
    </section>
  </main>
</BaseLayout>
