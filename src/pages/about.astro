---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Sandikala Studio"
  description="Sandikala Studio is a design and Webflow development studio crafting visually distinctive websites for brands that refuse to feel generic."
>
  <main class="about-page">
    <section class="hero">
      <p>About</p>
      <h1>
        Design-led websites with a sharp eye for craft, clarity, and
        interaction.
      </h1>
    </section>

    <section class="content">
      <div>
        <h2>Short version</h2>
      </div>

      <div>
        <p>
          Sandikala Studio is a small creative studio focused on brand, web
          design, and custom Webflow development. We help ambitious brands turn
          their visual identity and ideas into websites that feel distinctive,
          clear, and built to grow.
        </p>

        <p>
          Our work blends strong visual direction, thoughtful structure, and
          purposeful interaction. Not just a nice-looking page, but a digital
          experience that helps the brand feel more considered, credible, and
          memorable.
        </p>
      </div>
    </section>

    <section class="services">
      <p>Core focus</p>

      <div class="grid">
        <div>
          <h3>Website Design</h3>
          <p>
            Visual direction, page structure, responsive layouts, and design
            systems for polished marketing websites.
          </p>
        </div>

        <div>
          <h3>Webflow Development</h3>
          <p>
            Custom Webflow builds with clean CMS structure, responsive behavior,
            and interaction details.
          </p>
        </div>

        <div>
          <h3>Interaction & Motion</h3>
          <p>
            GSAP-powered motion, page transitions, scroll interactions, and
            subtle micro-interactions where they add value.
          </p>
        </div>
      </div>
    </section>

    <section class="cta">
      <h2>Have a site that needs to feel less generic?</h2>
      <a href="/contact">Start a conversation</a>
    </section>
  </main>
</BaseLayout>
