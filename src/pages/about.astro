---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<html lang="en">
  <head>
    <title>About | Sandikala Studio</title>
    <meta
      name="description"
      content="Sandikala Studio is a design and Webflow development studio crafting visually distinctive websites for brands that refuse to feel generic."
    />
  </head>

  <body>
    <BaseLayout
      title="About | Sandikala Studio"
      description="Sandikala Studio is a design and Webflow development studio crafting visually distinctive websites for brands that refuse to feel generic."
    >
      <main>
        <nav>
          <a href="/">Sandikala Studio</a>
          <div>
            <a href="/work">Work</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>

        <section class="hero">
          <p>About</p>
          <h1>
            Design-led websites with a sharp eye for craft, clarity, and
            interaction.
          </h1>
        </section>

        <section class="content">
          <div>
            <h2>Short version</h2>
          </div>

          <div>
            <p>
              Sandikala Studio is a small creative studio focused on brand, web
              design, and custom Webflow development. We help ambitious brands
              turn their visual identity and ideas into websites that feel
              distinctive, clear, and built to grow.
            </p>

            <p>
              Our work blends strong visual direction, thoughtful structure, and
              purposeful interaction. Not just a nice-looking page, but a
              digital experience that helps the brand feel more considered,
              credible, and memorable.
            </p>
          </div>
        </section>

        <section class="services">
          <p>Core focus</p>

          <div class="grid">
            <div>
              <h3>Website Design</h3>
              <p>
                Visual direction, page structure, responsive layouts, and design
                systems for polished marketing websites.
              </p>
            </div>

            <div>
              <h3>Webflow Development</h3>
              <p>
                Custom Webflow builds with clean CMS structure, responsive
                behavior, and interaction details.
              </p>
            </div>

            <div>
              <h3>Interaction & Motion</h3>
              <p>
                GSAP-powered motion, page transitions, scroll interactions, and
                subtle micro-interactions where they add value.
              </p>
            </div>
          </div>
        </section>

        <section class="cta">
          <h2>Have a site that needs to feel less generic?</h2>
          <a href="/contact">Start a conversation</a>
        </section>
      </main>
    </BaseLayout>
  </body>

  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: #f7f4ef;
      color: #171717;
    }

    main {
      padding: 32px 48px 80px;
    }

    nav {
      display: flex;
      justify-content: space-between;
      gap: 24px;
    }

    nav div {
      display: flex;
      gap: 20px;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    a:hover {
      opacity: 0.6;
    }

    .hero {
      margin-top: 120px;
    }

    .hero p,
    .services > p {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 13px;
    }

    h1 {
      max-width: 1100px;
      font-size: clamp(48px, 8vw, 120px);
      line-height: 0.9;
      letter-spacing: -0.06em;
      margin: 16px 0 0;
    }

    .content {
      display: grid;
      grid-template-columns: 0.8fr 1.2fr;
      gap: 48px;
      margin-top: 120px;
      border-top: 1px solid rgba(23, 23, 23, 0.2);
      padding-top: 32px;
    }

    .content h2 {
      font-size: 20px;
      margin: 0;
    }

    .content p {
      font-size: clamp(24px, 3vw, 42px);
      line-height: 1.15;
      letter-spacing: -0.04em;
      margin-top: 0;
    }

    .services {
      margin-top: 120px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
      margin-top: 24px;
    }

    .grid div {
      border: 1px solid rgba(23, 23, 23, 0.2);
      padding: 24px;
      min-height: 220px;
    }

    h3 {
      font-size: 24px;
      margin-top: 0;
    }

    .grid p {
      line-height: 1.5;
      opacity: 0.75;
    }

    .cta {
      margin-top: 120px;
      padding-top: 32px;
      border-top: 1px solid rgba(23, 23, 23, 0.2);
    }

    .cta h2 {
      max-width: 800px;
      font-size: clamp(40px, 6vw, 88px);
      line-height: 0.95;
      letter-spacing: -0.05em;
    }

    .cta a {
      display: inline-block;
      border: 1px solid currentColor;
      border-radius: 999px;
      padding: 12px 20px;
    }

    @media (max-width: 768px) {
      main {
        padding: 24px;
      }

      nav {
        flex-direction: column;
      }

      .hero,
      .content,
      .services,
      .cta {
        margin-top: 80px;
      }

      .content,
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</html>
