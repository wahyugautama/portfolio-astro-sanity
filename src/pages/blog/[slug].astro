---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../lib/sanityImage";
import { renderPortableText } from "../../lib/portableText";

type PostPath = {
  slug: string;
};

type Post = {
  title: string;
  slug: { current: string };
  excerpt?: string;
  publishedAt: string;
  mainImage?: any;
  body?: any[];
  author?: string;
  categories?: string[];
  seoTitle?: string;
  seoDescription?: string;
};

export async function getStaticPaths() {
  const posts: PostPath[] = await sanityClient.fetch(`
    *[_type == "post" && defined(slug.current)] {
      "slug": slug.current
    }
  `);

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
  }));
}

const { slug } = Astro.params;

const post: Post | null = await sanityClient.fetch(
  `
  *[_type == "post" && slug.current == $slug][0] {
    title,
    slug,
    excerpt,
    publishedAt,
    mainImage,
    body,
    author,
    categories,
    seoTitle,
    seoDescription
  }
`,
  { slug },
);

if (!post) {
  return Astro.redirect("/404");
}

const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const pageTitle = post.seoTitle || post.title;
const pageDescription = post.seoDescription || post.excerpt || post.title;
---

<BaseLayout
  title={`${pageTitle} | Sandikala Studio`}
  description={pageDescription}
>
  <main class="blog-post-page">
    <a href="/blog">← Back to blog</a>

    <article class="post-content">
      <header class="post-header">
        <h1>{post.title}</h1>

        <div class="post-meta">
          <time>{formatDate(post.publishedAt)}</time>
          {post.author && <span class="author">By {post.author}</span>}
        </div>

        {
          post.categories && post.categories.length > 0 && (
            <div class="categories">
              {post.categories.map((cat) => (
                <span class="category">{cat}</span>
              ))}
            </div>
          )
        }

        {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
      </header>

      {
        post.mainImage && (
          <img
            class="featured-image"
            src={urlFor(post.mainImage).width(1200).height(600).url()}
            alt={post.title}
          />
        )
      }

      {
        post.body && (
          <div class="post-body" set:html={renderPortableText(post.body)} />
        )
      }
    </article>
  </main>

  <style>
    .blog-post-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    a {
      color: inherit;
      text-decoration: none;
      font-weight: 500;
      opacity: 0.8;
      transition: opacity 0.3s ease;

      &:hover {
        opacity: 1;
      }
    }

    .post-content {
      margin-top: 2rem;
    }

    .post-header {
      margin-bottom: 2rem;
    }

    .post-header h1 {
      font-size: 2.5rem;
      margin: 1rem 0;
      line-height: 1.2;
    }

    .post-meta {
      display: flex;
      gap: 1rem;
      font-size: 0.95rem;
      opacity: 0.7;
      margin: 1rem 0;

      time {
        font-weight: 500;
      }

      .author::before {
        content: "•";
        margin-right: 0.5rem;
      }
    }

    .categories {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }

    .category {
      display: inline-block;
      background: rgba(0, 0, 0, 0.05);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .excerpt {
      font-size: 1.1rem;
      line-height: 1.6;
      opacity: 0.8;
      margin: 1.5rem 0;
      font-style: italic;
    }

    .featured-image {
      width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 2rem 0;
      display: block;
    }

    :global(.post-body) {
      line-height: 1.8;
      font-size: 1.05rem;
      margin: 2rem 0;

      p {
        margin-bottom: 1.5rem;
      }

      h1,
      h2,
      h3 {
        margin: 2rem 0 1rem;
        line-height: 1.3;
      }

      h1 {
        font-size: 2rem;
      }

      h2 {
        font-size: 1.5rem;
      }

      h3 {
        font-size: 1.25rem;
      }

      blockquote {
        border-left: 4px solid rgba(0, 0, 0, 0.1);
        padding-left: 1.5rem;
        margin: 2rem 0;
        font-style: italic;
        opacity: 0.8;
      }

      code {
        background: rgba(0, 0, 0, 0.05);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-family: "Courier New", monospace;
        font-size: 0.9em;
      }

      strong {
        font-weight: 600;
      }

      em {
        font-style: italic;
      }
    }
  </style>
</BaseLayout>
