---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../lib/sanityImage";

type Project = {
  title: string;
  slug: {
    current: string;
  };
  client?: string;
  year?: number;
  industry?: string;
  services?: string[];
  summary?: string;
  coverImage?: any;
  featured?: boolean;
};

const projects: Project[] = await sanityClient.fetch(`
  *[_type == "project"] | order(year desc) {
    title,
    slug,
    client,
    year,
    industry,
    services,
    summary,
    coverImage,
    featured
  }
`);
---

<BaseLayout
  title="Work | Sandikala Studio"
  description="Selected portfolio work."
>
  <main class="work-page">
    <section>
      <p>Selected Work</p>
      <h1>
        Visually striking websites for brands that refuse to feel generic.
      </h1>
    </section>

    <section class="grid">
      {
        projects.map((project) => (
          <a href={`/work/${project.slug.current}`} class="card">
            {project.coverImage && (
              <img
                src={urlFor(project.coverImage).width(1200).height(800).url()}
                alt={project.title}
              />
            )}

            <div>
              <p>
                {project.year} · {project.industry}
              </p>

              <h2>{project.title}</h2>

              {project.summary && <p>{project.summary}</p>}

              {project.services && (
                <ul>
                  {project.services.map((service) => (
                    <li>{service}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
