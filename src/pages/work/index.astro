---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../lib/sanityImage";

type Project = {
  title: string;
  slug: {
    current: string;
  };
  client?: string;
  year?: number;
  industry?: string;
  services?: string[];
  summary?: string;
  coverImage?: any;
  featured?: boolean;
};

const projects: Project[] = await sanityClient.fetch(`
  *[_type == "project"] | order(year desc) {
    title,
    slug,
    client,
    year,
    industry,
    services,
    summary,
    coverImage,
    featured
  }
`);
---

<html lang="en">
  <head>
    <title>Work | Sandikala Studio</title>
    <meta name="description" content="Selected portfolio work." />
  </head>

  <body>
    <BaseLayout title="Work | Sandikala Studio">
      <main>
        <section>
          <p>Selected Work</p>
          <h1>
            Visually striking websites for brands that refuse to feel generic.
          </h1>
        </section>

        <section class="grid">
          {
            projects.map((project) => (
              <a href={`/work/${project.slug.current}`} class="card">
                {project.coverImage && (
                  <img
                    src={urlFor(project.coverImage)
                      .width(1200)
                      .height(800)
                      .url()}
                    alt={project.title}
                  />
                )}

                <div>
                  <p>
                    {project.year} · {project.industry}
                  </p>

                  <h2>{project.title}</h2>

                  {project.summary && <p>{project.summary}</p>}

                  {project.services && (
                    <ul>
                      {project.services.map((service) => (
                        <li>{service}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </a>
            ))
          }
        </section>
      </main>
    </BaseLayout>
  </body>

  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: #f7f4ef;
      color: #171717;
    }

    main {
      padding: 48px;
    }

    h1 {
      max-width: 900px;
      font-size: clamp(48px, 8vw, 120px);
      line-height: 0.92;
      letter-spacing: -0.06em;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
      margin-top: 80px;
    }

    .card {
      color: inherit;
      text-decoration: none;
    }

    .card img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      display: block;
    }

    .card h2 {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .card p {
      max-width: 560px;
    }

    ul {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding: 0;
      list-style: none;
    }

    li {
      border: 1px solid currentColor;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 14px;
    }

    @media (max-width: 768px) {
      main {
        padding: 24px;
      }

      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</html>
