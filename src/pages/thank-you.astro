---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Thank You | Sandikala Studio"
  description="Thanks for contacting Sandikala Studio."
  theme="dark"
>
  <main class="thank-you-page">
    <nav class="thank-you-nav">
      <a href="/">Sandikala Studio</a>
      <div>
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <section class="thank-you">
      <p>Message sent</p>
      <h1>Thank you.</h1>
      <p class="intro">
        We received your enquiry and will get back to you soon.
      </p>
      <a class="button" href="/">Back to home</a>
    </section>
  </main>
</BaseLayout>
