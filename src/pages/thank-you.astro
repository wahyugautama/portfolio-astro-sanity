---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Thank You | Sandikala Studio"
  description="Thanks for contacting Sandikala Studio."
>
  <main>
    <nav>
      <a href="/">Sandikala Studio</a>
      <div>
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <section class="thank-you">
      <p>Message sent</p>
      <h1>Thank you.</h1>
      <p class="intro">
        We received your enquiry and will get back to you soon.
      </p>
      <a class="button" href="/">Back to home</a>
    </section>
  </main>
</BaseLayout>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #171717;
    color: #f7f4ef;
  }

  main {
    padding: 32px 48px 80px;
    min-height: 100vh;
    box-sizing: border-box;
  }

  nav {
    display: flex;
    justify-content: space-between;
    gap: 24px;
  }

  nav div {
    display: flex;
    gap: 20px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    opacity: 0.6;
  }

  .thank-you {
    margin-top: 160px;
    max-width: 1000px;
  }

  .thank-you > p:first-child {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    opacity: 0.7;
  }

  h1 {
    font-size: clamp(72px, 14vw, 180px);
    line-height: 0.86;
    letter-spacing: -0.08em;
    margin: 16px 0 32px;
  }

  .intro {
    max-width: 640px;
    font-size: clamp(24px, 3vw, 42px);
    line-height: 1.15;
    letter-spacing: -0.04em;
    opacity: 0.75;
  }

  .button {
    display: inline-block;
    margin-top: 40px;
    border: 1px solid currentColor;
    border-radius: 999px;
    background: #f7f4ef;
    color: #171717;
    padding: 14px 22px;
  }

  @media (max-width: 768px) {
    main {
      padding: 24px;
    }

    nav {
      flex-direction: column;
    }

    .thank-you {
      margin-top: 100px;
    }
  }
</style>
