---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  theme?: "light" | "dark";
};

const {
  title = "Sandikala Studio",
  description = "Design-led websites and custom Webflow development for brands that refuse to feel generic.",
  theme = "light",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <ClientRouter />
  </head>

  <body>
    <header class="site-header" transition:persist>
      <a href="/" class="brand">Sandikala Studio</a>

      <nav aria-label="Main navigation">
        <a href="/work">Work</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <div class="page-transition" transition:name="page">
      <slot />
    </div>

    <footer class="site-footer" transition:persist>
      <p>© {new Date().getFullYear()} Sandikala Studio</p>

      <div>
        <a href="mailto:hello@sandikalastudio.com">Email</a>
        <a
          href="https://cal.com/sandikalastudio"
          target="_blank"
          rel="noreferrer"
        >
          Book a call
        </a>
      </div>
    </footer>
  </body>
</html>
